# Server
APP_NAME=skillup-yolo-local
ENV=local

# Security
JWT_SECRET=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
# SQLite default (local)
DATABASE_URL=sqlite:///./app.db
# (Future) Postgres example:
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/skillup

# YOLO defaults (leves)
YOLO_WEIGHTS=./weights/yolov8n.pt
DEFAULT_IMGSZ=640
DEFAULT_CONF=0.25
DEFAULT_IOU=0.7

# Torch performance
TORCH_THREADS=4

# Storage
DATA_DIR=./data
UPLOADS_DIR=./data/uploads
OUTPUTS_DIR=./data/outputs

# CORS (locked)
CORS_ORIGINS=http://localhost:3000
